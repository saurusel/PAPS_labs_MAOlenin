@startuml
title GoF — Chain of Responsibility
' ЛР6 — GoF UML
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam ArrowThickness 1
skinparam RoundCorner 12
skinparam defaultTextAlignment center
hide empty members
left to right direction

abstract class Handler {
  +set_next(handler)
  +handle(context)
}

class UserIdValidator
class ItemsValidator
class BalanceValidator
class StatusTransitionValidator

Handler <|-- UserIdValidator
Handler <|-- ItemsValidator
Handler <|-- BalanceValidator
Handler <|-- StatusTransitionValidator

UserIdValidator --> ItemsValidator : next
ItemsValidator --> BalanceValidator : next
BalanceValidator --> StatusTransitionValidator : next
@enduml
